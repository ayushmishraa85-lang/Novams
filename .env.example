# Railway automatically injects DATABASE_URL when you add a PostgreSQL plugin.
# For local development, set it yourself, e.g.:
DATABASE_URL=postgresql://user:password@localhost:5432/bidashboard

# Secret used to sign JWT auth tokens - set this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Port the server listens on (Railway sets this automatically)
PORT=3000
